# =====================================
# d20 VTT — Backend Environment Example
# =====================================
# Copy this to .env and fill in your values.

# ── Server ───────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
SOCKET_IO_PATH=/socketio

# ── Security ─────────────────────────
JWT_SECRET=change-me-to-a-random-string
DM_SECRET=change-me-to-another-random-string

# ── CORS ─────────────────────────────
# Comma-separated list of additional allowed origins
CLIENT_ORIGIN=http://localhost:4200

# ── Redis (optional) ─────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_SESSION_TTL=86400

# ── Persistence ──────────────────────
PERSISTENCE_PATH=./data/rooms.json

# ── Discord OAuth2 (optional) ────────
# DISCORD_CLIENT_ID=your-discord-client-id
# DISCORD_CLIENT_SECRET=your-discord-client-secret
# DISCORD_REDIRECT_URI=https://your-app.com/auth/discord/callback

# ── Cloudinary (optional) ────────────
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
# CLOUDINARY_UPLOAD_FOLDER=d20-uploads

# ── Automation API (optional) ────────
# AUTOMATION_ENABLED=false
# AUTOMATION_TOKEN=your-automation-token
# AUTOMATION_LOCAL_ONLY=true
